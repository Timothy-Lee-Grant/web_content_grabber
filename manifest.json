{
  "manifest_version": 3,
  "name": "Job Grabber",
  "version": "1.0.0",
  "description": "Grab a job description from any web page and save it as a Markdown file with metadata.",
  "permissions": ["activeTab", "scripting", "downloads", "storage"],
  "action": {
    "default_popup": "src/popup.html",
    "default_title": "Job Grabber"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
